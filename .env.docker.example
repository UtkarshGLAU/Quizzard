# Backend Environment Variables for Docker
MONGODB_URI=mongodb://mongo:27017/quizzard
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
ADMIN_EMAILS=admin1@example.com,admin2@example.com
GEMINI_API_KEY=your_gemini_api_key_here
PORT=5000
NODE_ENV=production

# Frontend Environment Variables for Docker
# Note: In Coolify, set VITE_API_URL to your actual backend URL
# For local docker-compose: http://backend:5000/api
# For deployed: https://api.your-domain.com
VITE_API_URL=http://backend:5000/api
